      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "http_route" },
            "properties": [{ "id": "displayName", "value": "Route" }]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [{ "id": "displayName", "value": "P95 Latency" }]
          }
        ]
      },
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "le": true } } }
      ]
    }
